# WLAN Configuration
WIFI_SSID=IOT_WIFI
WIFI_PASSWORD=

# MQTT Broker Configuration
MQTT_BROKER=thingsboard
MQTT_PORT=1883

# ThingsBoard HTTP API Configuration
THINGSBOARD_USERNAME=
THINGSBOARD_BASE_URL=http://thingsboard:8080
THINGSBOARD_LOGIN_PATH=/api/auth/login
THINGSBOARD_RPC_PATH=/api/rpc/twoway/%s
THINGSBOARD_USER_PATH=/api/auth/user
THINGSBOARD_VERIFY_PATH=/api/auth/2fa/verification/check?providerType=TOTP&verificationCode=%s
THINGSBOARD_DEVICE_INFO_PATH=/api/tenant/deviceInfos?pageSize=100&page=0&sortProperty=name&sortOrder=ASC
THINGSBOARD_DEVICE_ATTRIBUTE_PATH=/api/plugins/telemetry/DEVICE/%s/values/attributes/CLIENT_SCOPE

# Dev Device Configuration
DEVICE_ID_DEV=ec870240-5c86-11f1-92d9-93754c56e8e7
DEVICE_AT_DEV=
DEVICE_LOCATION_DEV=Testdevice

